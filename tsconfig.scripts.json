{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": ".scripts-build",
    "rootDir": "."
  },
  "include": ["scripts/**/*.ts", "lib/pricing/**/*.ts"]
}


